[user]
  name = Leo Chatain
  email = leochatain@gmail.com

[color]
  ui = true

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red bold
  new = green bold
  whitespace = red reverse

[color "status"]
  added = yellow
  changed = green
  untracked = cyan

[color "decorate"]
  HEAD = bold cyan
  branch = bold green
  remoteBranch = red
  tag = bold yellow
  stash = magenta

[core]
  whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol
  excludesfile = ~/.gitignore_global
  pager = delta

[pager]
  log = less -FRX

[init]
  defaultBranch = main

[push]
  autoSetupRemote = true

[pull]
  rebase = true

[rerere]
  enabled = true

[diff]
  colorMoved = zebra
  algorithm = histogram
  renames = copies

[fetch]
  prune = true

[branch]
  autoSetupMerge = true

[merge]
  conflictstyle = zdiff3

[rebase]
  autoStash = true
  updateRefs = true

[log]
  date = iso

[column]
  ui = auto

[help]
  autocorrect = prompt

[tag]
  sort = -version:refname

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  side-by-side = true
  line-numbers = true
  syntax-theme = 1337

[alias]
  st = status
  co = checkout
  sw = switch
  swc = switch -c
  rs = restore
  rss = restore --staged
  br = branch
  ci = commit
  cm = commit -m
  cam = commit -am
  pushf = push --force-with-lease
  unstage = reset HEAD --
  last = log -1 HEAD
  xl = log --graph --decorate --pretty=format:'%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --oneline --all
  xlc = log --graph --decorate --pretty=format:'%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --oneline
  xls = "!f() { ESC=$(printf '\\033'); S=$(git diff --cached --name-only 2>/dev/null | wc -l | tr -d ' '); U=$(git diff --name-only 2>/dev/null | wc -l | tr -d ' '); T=$(git ls-files --others --exclude-standard 2>/dev/null | wc -l | tr -d ' '); H=\"\"; SEP=\"\"; [ $S -gt 0 ] && { H=\"$H$SEP${ESC}[38;5;178m+$S staged${ESC}[m\"; SEP=\"  \"; }; [ $U -gt 0 ] && { H=\"$H$SEP${ESC}[38;5;178m!$U unstaged${ESC}[m\"; SEP=\"  \"; }; [ $T -gt 0 ] && { H=\"$H$SEP${ESC}[36m?$T untracked${ESC}[m\"; SEP=\"  \"; }; { [ -n \"$H\" ] && echo \"[ $H ]\"; git -c color.ui=always --no-pager xl \"$@\" | awk '/HEAD/{sub(/\\*/,\"●\");gsub(/\\033\\[m/,\"\\033[m\\033[1m\");printf \"%c[1m%s%c[22m\\n\",27,$0,27;next}1'; } | less -FRX; }; f \"$@\""
  amend = commit --amend --no-edit
  reword = commit --amend --only
  undo = reset --soft HEAD^
  uncommit = reset --soft HEAD~1
  tags = tag -l

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  required = true
  process = git-lfs filter-process

[lfs "customtransfer.xet"]
  path = git-xet
  args = transfer
  concurrent = true
