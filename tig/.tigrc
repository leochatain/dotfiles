# Trim main view to match `git xl`: <hash> | <graph> <refs> <subject>
# Date and author are hidden by default; toggle with D and A inside tig.
set main-view = id:yes date:yes,display=relative-compact author:no commit-title:graph=yes,refs=yes,overflow=no
set id-width = 7

# Quality of life
set tab-size = 2
set vertical-split = no
set show-changes = yes
set diff-options = --patch-with-stat -m
set mouse = yes
set wrap-lines = yes
set ignore-case = smart-case
set blame-options = -C -C -C
set commit-order = topo

# Vim-friendly navigation
bind generic g  move-first-line
bind generic G  move-last-line
bind generic <C-f> move-page-down
bind generic <C-b> move-page-up
bind generic Q  quit
bind generic w  :toggle wrap-lines
bind main    Y  !@sh -c "printf %s %(commit) | pbcopy"
bind diff    Y  !@sh -c "printf %s %(commit) | pbcopy"
